generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id        String   @id
  vin       String
  brand     String
  model     String
  year      Int
  mileage   Int
  createdAt DateTime @default(now())

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
}

model User {
  id           String    @id
  email        String    @unique
  passwordHash String
  createdAt    DateTime

  vehicles     Vehicle[]
}